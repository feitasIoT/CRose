<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="feitas_iot.OverviewDashboard">
        <div class="o_action p-4">
            <div class="mb-3">
                <h2 class="m-0">Overview</h2>
            </div>
            <div class="row g-3">
                <div class="col-12 col-lg-6">
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <div class="border rounded p-3 bg-white h-100">
                                <div class="d-flex align-items-center justify-content-between mb-2">
                                    <h5 class="m-0">Platform</h5>
                                    <i class="fa fa-question-circle text-muted" title="Show the runtime status of key platform components, including the MQTT Broker, NPM Registry, and local instances." style="cursor: pointer;"></i>
                                </div>
                                <t t-if="state.loading">
                                    <div class="text-muted">Loading...</div>
                                </t>
                                <t t-elif="state.error">
                                    <div class="text-danger" t-esc="state.error"/>
                                </t>
                                <t t-else="">
                                    <div class="row g-3 feitas_iot_dashboard_gauges">
                                        <t t-foreach="state.components" t-as="component" t-key="component.id">
                                            <div class="col-12">
                                                <div class="feitas_iot_dashboard_gauge">
                                                    <div class="d-flex align-items-baseline justify-content-between">
                                                        <div class="fw-semibold" t-esc="component.name"/>
                                                        <div class="text-muted">
                                                            <span t-att-class="'badge text-bg-' + (component.status === 'online' ? 'success' : 'danger')" t-esc="component.status"/>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                    </div>
                                </t>
                            </div>
                        </div>
                        <div class="col-12 col-md-6">
                            <div class="border rounded p-3 bg-white h-100">
                                <div class="d-flex align-items-center justify-content-between mb-2">
                                    <h5 class="m-0">Statistics</h5>
                                    <i class="fa fa-question-circle text-muted" title="Show the number of key platform resources, such as edge agents, application instances, and MQTT topics." style="cursor: pointer;"></i>
                                </div>
                                <t t-if="state.loading">
                                    <div class="text-muted">Loading...</div>
                                </t>
                                <t t-elif="state.error">
                                    <div class="text-danger" t-esc="state.error"/>
                                </t>
                                <t t-else="">
                                    <t t-set="agentCount" t-value="(state.overview &amp;&amp; state.overview.stats &amp;&amp; state.overview.stats.agents) || 0"/>
                                    <t t-set="instanceCount" t-value="(state.overview &amp;&amp; state.overview.stats &amp;&amp; state.overview.stats.instances) || 0"/>
                                    <t t-set="topicCount" t-value="(state.overview &amp;&amp; state.overview.stats &amp;&amp; state.overview.stats.topics) || 0"/>
    
                                    <div class="d-flex gap-2 feitas_iot_dashboard_kpis">
                                        <div class="border rounded p-2 bg-light feitas_iot_dashboard_kpi">
                                            <div class="text-muted small">Agents</div>
                                            <div class="feitas_iot_dashboard_kpi_value">
                                                <t t-esc="agentCount"/>
                                            </div>
                                        </div>
                                        <div class="border rounded p-2 bg-light feitas_iot_dashboard_kpi">
                                            <div class="text-muted small">Instances</div>
                                            <div class="feitas_iot_dashboard_kpi_value">
                                                <t t-esc="instanceCount"/>
                                            </div>
                                        </div>
                                        <div class="border rounded p-2 bg-light feitas_iot_dashboard_kpi">
                                            <div class="text-muted small">Topics</div>
                                            <div class="feitas_iot_dashboard_kpi_value">
                                                <t t-esc="topicCount"/>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-6">
                    <div class="d-flex flex-column gap-3">
                        <div class="border rounded p-3 bg-white">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <h5 class="m-0">To Do</h5>
                                <i class="fa fa-question-circle text-muted" title="This section lists pending items that need attention." style="cursor: pointer;"></i>
                            </div>
                            <div class="text-muted">No pending items</div>
                        </div>

                        <div class="border rounded p-3 bg-white">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <h5 class="m-0">Messages</h5>
                                <i class="fa fa-question-circle text-muted" title="This section shows the latest system activity." style="cursor: pointer;"></i>
                            </div>
                            <t t-if="state.logs and state.logs.length">
                                <div class="d-flex flex-column gap-2">
                                    <t t-foreach="state.logs" t-as="log" t-key="log.id">
                                        <div class="border rounded p-2">
                                            <div class="text-muted small">
                                                <t t-esc="formatLogCreateDate(log.create_date)"/>
                                            </div>
                                            <div>
                                                <t t-esc="log.message"/>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </t>
                            <t t-else="">
                                <div class="text-muted">No recent activity</div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
