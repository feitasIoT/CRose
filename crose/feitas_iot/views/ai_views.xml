<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_fts_ai_model_list" model="ir.ui.view">
            <field name="name">fts.ai.model.list</field>
            <field name="model">fts.ai.model</field>
            <field name="arch" type="xml">
                <list string="AI Models">
                    <field name="name"/>
                    <field name="is_active" widget="boolean_toggle"/>
                    <field name="local_path"/>
                </list>
            </field>
        </record>

        <record id="view_fts_ai_model_form" model="ir.ui.view">
            <field name="name">fts.ai.model.form</field>
            <field name="model">fts.ai.model</field>
            <field name="arch" type="xml">
                <form string="AI Model">
                    <header>
                        <button name="action_deploy_model" string="Deploy and Activate Model" type="object" class="btn-primary" icon="fa-cloud-upload"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name" placeholder="For example: paraphrase-multilingual-MiniLM-L12-v2"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Model Configuration">
                                <field name="model_file" filename="model_filename"/>
                                <field name="is_active" readonly="1"/>
                            </group>
                            <group string="Local Status">
                                <field name="local_path" readonly="1"/>
                            </group>
                        </group>
                        <div class="alert alert-info" role="alert" invisible="not is_active">
                            <i class="fa fa-info-circle"/> This model is currently active and can be used by the system.
                        </div>
                        <div class="alert alert-warning" role="alert" invisible="is_active">
                            <i class="fa fa-exclamation-triangle"/> This model is not active yet. Upload the archive and click "Deploy and Activate Model".
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_fts_ai_dataset_list" model="ir.ui.view">
            <field name="name">fts.ai.dataset.list</field>
            <field name="model">fts.ai.dataset</field>
            <field name="arch" type="xml">
                <list string="Datasets">
                    <field name="name"/>
                </list>
            </field>
        </record>

        <record id="view_fts_ai_dataset_form" model="ir.ui.view">
            <field name="name">fts.ai.dataset.form</field>
            <field name="model">fts.ai.dataset</field>
            <field name="arch" type="xml">
                <form string="Dataset">
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_fts_ai_training_list" model="ir.ui.view">
            <field name="name">fts.ai.training.list</field>
            <field name="model">fts.ai.training</field>
            <field name="arch" type="xml">
                <list string="Model Training">
                    <field name="name"/>
                </list>
            </field>
        </record>

        <record id="view_fts_ai_training_form" model="ir.ui.view">
            <field name="name">fts.ai.training.form</field>
            <field name="model">fts.ai.training</field>
            <field name="arch" type="xml">
                <form string="Model Training">
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>

