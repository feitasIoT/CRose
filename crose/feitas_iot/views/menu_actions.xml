<odoo>
    <data>


        <!-- Actions -->
        <record id="action_fts_nr_instance" model="ir.actions.act_window">
            <field name="name">Instances</field>
            <field name="res_model">fts.nr.instance</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="context">{'search_default_group_by_instance_type': 1}</field>
            <field name="view_ids" eval="[
                (5, 0, 0),
                (0, 0, {'view_mode': 'kanban', 'view_id': ref('feitas_iot.view_fts_instance_kanban')}),
                (0, 0, {'view_mode': 'list', 'view_id': ref('feitas_iot.view_fts_instance_tree')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('feitas_iot.view_fts_instance_form')})
            ]"/>
        </record>
        <record id="action_fts_nr_flow" model="ir.actions.act_window">
            <field name="name">Flows</field>
            <field name="res_model">fts.nr.flow</field>
            <field name="view_mode">kanban,list,form</field>
        </record>
        <record id="action_fts_nr_flow_template" model="ir.actions.act_window">
            <field name="name">Template Applications</field>
            <field name="res_model">fts.nr.flow</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="domain">[('is_template', '=', True)]</field>
            <field name="context">{'default_is_template': True}</field>
        </record>
        <record id="action_fts_nr_node" model="ir.actions.act_window">
            <field name="name">Nodes</field>
            <field name="res_model">fts.nr.node</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Server action: synchronize flows to the knowledge base -->
        <record id="action_sync_flow_to_knowledge" model="ir.actions.server">
            <field name="name">Synchronize Knowledge Base</field>
            <field name="model_id" ref="model_fts_nr_flow"/>
            <field name="binding_model_id" ref="model_fts_nr_flow"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">
                if records:
                    action = records.action_sync_to_knowledge()
            </field>
        </record>

        <!-- Server action: synchronize nodes to the knowledge base -->
        <record id="action_sync_node_to_knowledge" model="ir.actions.server">
            <field name="name">Synchronize Knowledge Base</field>
            <field name="model_id" ref="model_fts_nr_node"/>
            <field name="binding_model_id" ref="model_fts_nr_node"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">
                if records:
                    action = records.action_sync_to_knowledge()
            </field>
        </record>
        <record id="action_fts_edge_agent" model="ir.actions.act_window">
            <field name="name">Agents</field>
            <field name="res_model">fts.edge.agent</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="view_ids" eval="[
                (5, 0, 0),
                (0, 0, {'view_mode': 'kanban', 'view_id': ref('feitas_iot.view_fts_edge_agent_kanban')}),
                (0, 0, {'view_mode': 'list', 'view_id': ref('feitas_iot.view_fts_edge_agent_tree')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('feitas_iot.view_fts_edge_agent_form')})
            ]"/>
        </record>

        <record id="action_fts_iot_overview" model="ir.actions.client">
            <field name="name">Overview</field>
            <field name="tag">feitas_iot.overview</field>
        </record>


        <!-- Root menu -->
        <menuitem id="menu_fts_iot_root" 
            name="CRose" 
            web_icon="feitas_iot,static/description/icon.png"
            sequence="1"/>
        <!-- Overview -->
        <menuitem
            id="menu_fts_iot_overview"
            name="Overview"
            parent="menu_fts_iot_root"
            action="action_fts_iot_overview"
            sequence="2"
        />
        <!-- Data Center -->
        <menuitem id="menu_fts_iot_data" 
            name="Data Center" parent="menu_fts_iot_root" sequence="5"/>
        
        
        <record id="action_fts_data_model" model="ir.actions.act_window">
            <field name="name">Data Modeling</field>
            <field name="res_model">fts.data.model</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem
            id="menu_fts_data_model"
            name="Data Modeling"
            parent="menu_fts_iot_data"
            action="action_fts_data_model"
            sequence="10"
        />

        <!-- Edge Computing -->
        <menuitem
            id="menu_fts_iot_edge"
            name="Edge Computing"
            parent="menu_fts_iot_root"
            sequence="10"
        />
        <menuitem
            id="menu_fts_iot_nr_agent"
            name="Agents"
            parent="menu_fts_iot_edge"
            action="action_fts_edge_agent"
            sequence="10"
        />
        <menuitem
            id="menu_fts_iot_nr_instance"
            name="Instances"
            parent="menu_fts_iot_edge"
            action="action_fts_nr_instance"
            sequence="20"
        />
        <menuitem
            id="menu_fts_iot_nr_flow"
            name="Applications"
            parent="menu_fts_iot_edge"
            action="action_fts_nr_flow"
            sequence="30"
        />
        <menuitem
            id="menu_fts_iot_nr_node"
            name="Nodes"
            parent="menu_fts_iot_edge"
            action="action_fts_nr_node"
            sequence="40"
        />

        <menuitem
            id="menu_fts_knowledge"
            name="Knowledge Base"
            parent="menu_fts_iot_root"
            action="feitas_iot.action_fts_knowledge"
            sequence="15"
        />

        <!-- Template Library -->
        <menuitem id="menu_fts_library" name="Template Library" parent="menu_fts_iot_root" sequence="35"/>

        <menuitem
            id="menu_fts_library_flow"
            name="Applications"
            parent="menu_fts_library"
            action="action_fts_nr_flow_template"
            sequence="10"
        />

        <!-- MQTT -->
        <menuitem id="menu_fts_mqtt_root" name="MQTT" parent="menu_fts_iot_root" sequence="40"/>

        <record id="action_fts_mqtt_user" model="ir.actions.act_window">
            <field name="name">MQTT Users</field>
            <field name="res_model">fts.mqtt.user</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem
            id="menu_fts_mqtt_user"
            name="MQTT Users"
            parent="menu_fts_mqtt_root"
            action="action_fts_mqtt_user"
            sequence="5"
        />

        <!-- Explicit menu entry as a fallback when the action menu is unavailable -->
        <menuitem id="menu_fts_mqtt_topic_sync"
                  name="Synchronize Topics Now"
                  parent="menu_fts_mqtt_root"
                  action="action_sync_mqtt_topics"
                  sequence="11"/>

        <!-- Menu -->
        <menuitem id="menu_fts_mqtt_topic"
                  name="Topics"
                  parent="menu_fts_mqtt_root"
                  action="action_fts_mqtt_topic"
                  sequence="10"/>
                  

        <!-- AI -->
        <menuitem id="menu_fts_ai_root" name="Deep Learning" parent="menu_fts_iot_root" sequence="50"/>

        <record id="action_fts_ai_model" model="ir.actions.act_window">
            <field name="name">AI Models</field>
            <field name="res_model">fts.ai.model</field>
            <field name="view_mode">list,form</field>
        </record>
        <record id="action_fts_ai_dataset" model="ir.actions.act_window">
            <field name="name">Datasets</field>
            <field name="res_model">fts.ai.dataset</field>
            <field name="view_mode">list,form</field>
        </record>
        <record id="action_fts_ai_training" model="ir.actions.act_window">
            <field name="name">Model Training</field>
            <field name="res_model">fts.ai.training</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_fts_ai_model" name="AI Models" parent="menu_fts_ai_root" action="action_fts_ai_model" sequence="10"/>
        <menuitem id="menu_fts_ai_dataset" name="Datasets" parent="menu_fts_ai_root" action="action_fts_ai_dataset" sequence="20"/>
        <menuitem id="menu_fts_ai_training" name="Model Training" parent="menu_fts_ai_root" action="action_fts_ai_training" sequence="30"/>


        <!-- Configuration -->
        <menuitem id="menu_fts_crose_config" 
            name="Configuration" parent="menu_fts_iot_root" sequence="100"/>

        <record id="action_fts_agent_release" model="ir.actions.act_window">
            <field name="name">Agent Package</field>
            <field name="res_model">ir.attachment</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_fts_agent_release" 
            name="Agent Package" parent="menu_fts_crose_config" action="action_fts_agent_release" sequence="10"/>

        <menuitem
            id="menu_crose_component"
            name="System Components"
            parent="menu_fts_crose_config"
            action="action_crose_component"
            sequence="20"
        />

        <record id="action_fts_nr_tag" model="ir.actions.act_window">
            <field name="name">Tags</field>
            <field name="res_model">fts.nr.tag</field>
            <field name="view_mode">list</field>
        </record>

        <menuitem
            id="menu_fts_nr_tag"
            name="Tags"
            parent="menu_fts_crose_config"
            action="action_fts_nr_tag"
            sequence="30"
        />

        

    </data>
 </odoo>
