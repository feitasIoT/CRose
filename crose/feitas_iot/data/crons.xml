<odoo>
    <data noupdate="1">

        <!-- Scheduled job: update integrated system status -->
        <record id="ir_cron_integration_status_update" model="ir.cron">
            <field name="name">Integrated System Status Update</field>
            <field name="model_id" ref="model_crose_component"/>
            <field name="state">code</field>
            <field name="code">model.search([]).action_check_status()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>


    </data>
</odoo>
